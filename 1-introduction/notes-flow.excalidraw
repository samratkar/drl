      "index": "b07",
      "roundness": null,
      "seed": 2108249329,
      "version": 921,
      "versionNonce": 222607775,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776014329907,
      "link": null,
      "locked": false,
      "text": "State Value of a state si : A stochastic leading value\nfunctions from a given state si to the goal, based on\nconditional probability from a state to the goal - for all\npossible episodes,, all possible transitions",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "State Value of a state si : A stochastic leading value functions from a given state si to the goal, based on conditional probability from a state to the goal - for all possible episodes,, all possible transitions",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "9OPL28PUPKw2BWO1U7C3i",
      "type": "text",
      "x": 778.3811950683594,
      "y": 288.2332763671875,
      "width": 444.6672973632814,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b08",
      "roundness": null,
      "seed": 1737020305,
      "version": 1592,
      "versionNonce": 1744903153,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776014547593,
      "link": null,
      "locked": false,
      "text": "Action value for a given state after an action a is\ntaken, is the expected return starting from state s,\ntaking action a, and then following policy π",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Action value for a given state after an action a is taken, is the expected return starting from state s, taking action a, and then following policy π",
      "autoResize": false,
      "lineHeight": 1.25
    },
