      "text": "return of a state si : sampled lagging value\nfunction for a given episode, after an\nepisode has ended",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "return of a state si : sampled lagging value function for a given episode, after an episode has ended",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "rZ10NRPLEyMcwV5TV9QBU",
      "type": "text",
      "x": 781.4372863769531,
      "y": 96.9442138671875,
      "width": 444.6672973632814,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
